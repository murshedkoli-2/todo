# ─── Required ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (replace <user>, <password>, <cluster>)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# NextAuth secret — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Full public URL of your app (no trailing slash)
# Development:  http://localhost:3000
# Production:   https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ─── Email (OTP / password reset via Gmail) ──────────────────────────────────
# Use an App Password (not your regular Gmail password)
# Guide: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Image uploads (ImgBB) ───────────────────────────────────────────────────
# Get your key at: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# ─── Admin PIN (optional — used for protected admin routes) ──────────────────
AUTH_PIN=your_4_digit_pin
