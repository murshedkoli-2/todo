MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# NextAuth v5 uses AUTH_SECRET; NEXTAUTH_SECRET is kept for compatibility
AUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000
IMGBB_API_KEY=your-imgbb-api-key-here

# Gmail SMTP for sending registration verification OTP
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here
